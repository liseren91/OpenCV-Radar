# ---- Job Radar self-host configuration ----

# Comma-separated search queries (used by both API adapters and scrapers).
JOB_QUERIES=product manager,marketing technology,AI product

# Location for scrapers (JobSpy format: "City, Country" or "Remote").
JOB_LOCATION=Belgrade, Serbia

# Which JobSpy scrapers to run: linkedin, indeed, glassdoor, google, zip_recruiter.
# Leave empty to disable scraping (API sources only).
JOBSPY_SITES=linkedin,indeed

# Results wanted per site per query (keep modest to avoid blocks).
JOBSPY_RESULTS=25

# Drop jobs older than this many days.
JOB_FRESH_DAYS=14

# Require the job TITLE to match a query (drops full-text noise like sales jobs
# that merely mention "product manager" in the description). strict | off
JOB_TITLE_FILTER=strict

# Refresh interval in hours (the worker loops forever).
FETCH_INTERVAL_HOURS=12

# Optional: Adzuna API keys (free at https://developer.adzuna.com) for the Adzuna source.
#ADZUNA_APP_ID=
#ADZUNA_APP_KEY=

# ---- Source registry (localhost-only, runs on top of the Node pipeline + JobSpy) ----
# 13 extra sources (API / RSS / HTML) scraped on YOUR machine. All enabled by default.
# Whitelist of source NAMEs to run (empty = all defaults on). Available names:
#   working_nomads, jooble, workable, jobspresso, nodesk, habr_career, geekjob,
#   poslovi, helloworld, startit, hubstaff, justremote, virtual_vocations
#SOURCES_ENABLED=
# Blacklist of source NAMEs to skip (takes precedence over the whitelist).
#SOURCES_DISABLED=
# Jooble needs a free API key (https://jooble.org/api/about); without it Jooble is skipped.
#JOOBLE_API_KEY=
# Politeness knobs for the shared HTTP client (seconds).
#SOURCES_THROTTLE=1.0
#SOURCES_TIMEOUT=30
#SOURCES_USER_AGENT=JobRadar-selfhost/1.0 (+https://github.com/job-radar; personal job search)
